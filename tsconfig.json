{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "convex/_generated/*": ["./convex/_generated/*"]
    }
  },
  "include": ["convex/**/*.ts"],
  "exclude": ["node_modules"]
}
